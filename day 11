import matplotlib.pyplot as plt

dates = ["MON", "TUE", "WED", "THU", "FRI"]
sales = [200, 250, 300, 280, 350]

plt.figure(figsize=(8, 5))

plt.plot(
    dates,
    sales,
    marker='o',
    linewidth=2
)

# Add value labels
for i, value in enumerate(sales):
    plt.text(dates[i], value + 5, str(value))

plt.title("Sales Trend Analysis")
plt.xlabel("Days")
plt.ylabel("Sales")
plt.grid(True)

plt.show()
